  "keyFeatures": [
    "Durable execution with PostgreSQL-backed workflows",
    "Real-time SSE streaming of agent responses and tool calls",
    "Multi-provider LLM support (OpenAI, Anthropic, Gemini)",
    "Extensible capabilities system for modular agent functionality",
    "Session filesystem and key-value storage",
    "MCP (Model Context Protocol) server integration",
    "Management UI and CLI for agents and sessions",
    "Cloud sandbox integrations (Docker, CodeSandbox, Daytona)"
  ],
  "publicApiSurface": [
    "POST /v1/agents - Create agent",
    "GET /v1/agents - List agents",
    "POST /v1/sessions - Create session",
    "GET /v1/sessions - List sessions",
    "POST /v1/sessions/{id}/messages - Send message",
    "GET /v1/sessions/{id}/sse - Stream events",
    "GET /v1/capabilities - List capabilities",
    "GET /v1/llm-providers - List LLM providers",
    "POST /v1/llm-providers/{id}/sync-models - Sync models",
    "everruns CLI - Command-line interface",
